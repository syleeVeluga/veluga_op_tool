PORT=8080
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
# Production CORS example (main/root only):
# CORS_ORIGIN=https://<github-id>.github.io
# If project-page path is used, add CSV origins (no spaces):
# CORS_ORIGIN=https://<github-id>.github.io,https://<github-id>.github.io/<repo>

# Planned for next phases
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB_NAME=logdb
OPS_TOOL_DB_NAME=ops_tool

# Multi-Cluster Configuration (Optional)
# 클러스터가 물리적으로 분리되어 각각 고유한 접속 주소를 가지는 경우 'uri' 속성을 추가합니다.
# veluga-app은 기본 MONGODB_URI를 사용하고, pnu-agent와 ubion-app은 각각의 클러스터 URI를 지정합니다.
# Example: 
# BATCH_DB_CONFIGS='[{"name":"veluga-app","dbName":"veluga_db"},{"name":"pnu-agent","dbName":"pnu_db","uri":"mongodb+srv://<user>:<password>@pnu-cluster/..."},{"name":"ubion-app","dbName":"ubion_db","uri":"mongodb+srv://<user>:<password>@ubion-cluster/..."}]'

# Custom collections can also be mapped if they differ from defaults (chats, usagelogs, botchats, channels, users)
# BATCH_DB_CONFIGS='[{"name":"pnu-agent","dbName":"pnu_db","uri":"mongodb+srv://...","collections":{"chats":"pnu_chats"}}]'

JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=8h
SUPER_ADMIN_EMAILS=syleee@veluga.io,sylee@veluga.io
SUPER_ADMIN_INITIAL_PASSWORD=ChangeMe123!
MAX_EXPORT_ROWS=10000
CSV_TRUNCATE_LENGTH=5000
MAX_CONCURRENT_EXPORTS=2
QUERY_TIMEOUT_MS=30000

