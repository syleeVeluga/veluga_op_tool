PORT=8080
NODE_ENV=development

# CORS — 허용할 프론트엔드 origin (쉼표로 복수 지정)
CORS_ORIGIN=http://localhost:5173
# Production examples:
# CORS_ORIGIN=https://myid.github.io
# CORS_ORIGIN=https://myid.github.io,https://myid.github.io/veluga_op_tool

# ── MongoDB ──────────────────────────────────────────────
# Atlas 연결 문자열 (Atlas UI → Connect → Drivers 에서 복사)
MONGODB_URI=mongodb+srv://myuser:mypassword@mycluster.abc12.mongodb.net/?retryWrites=true&w=majority
# 조회 대상 DB (고객 로그가 들어있는 DB)
MONGODB_DB_NAME=veluga_db
# 대시보드 자체 데이터 저장 DB (사용자 계정, 설정 등)
OPS_TOOL_DB_NAME=ops_tool

# ── Multi-Cluster (Optional) ────────────────────────────
# 클러스터가 물리적으로 분리되어 각각 고유한 접속 주소를 가지는 경우 'uri' 속성을 추가합니다.
# veluga-app은 기본 MONGODB_URI를 사용하고, pnu-agent와 ubion-app은 각각의 클러스터 URI를 지정합니다.
# Example:
# BATCH_DB_CONFIGS='[{"name":"veluga-app","dbName":"veluga_db"},{"name":"pnu-agent","dbName":"pnu_db","uri":"mongodb+srv://user:pass@pnu-cluster.abc12.mongodb.net/..."},{"name":"ubion-app","dbName":"ubion_db","uri":"mongodb+srv://user:pass@ubion-cluster.abc12.mongodb.net/..."}]'
#
# Custom collections can also be mapped if they differ from defaults (chats, usagelogs, botchats, channels, users)
# BATCH_DB_CONFIGS='[{"name":"pnu-agent","dbName":"pnu_db","uri":"mongodb+srv://...","collections":{"chats":"pnu_chats"}}]'

# ── Auth ─────────────────────────────────────────────────
# JWT 서명 키 (openssl rand -hex 32 등으로 생성)
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=8h
# 최초 기동 시 super_admin 으로 자동 생성될 이메일
SUPER_ADMIN_EMAILS=admin@example.com
# 자동 생성 시 초기 비밀번호 (로그인 후 변경 권장)
SUPER_ADMIN_INITIAL_PASSWORD=ChangeMe123!

# ── Query / Export Limits ────────────────────────────────
MAX_EXPORT_ROWS=10000
CSV_TRUNCATE_LENGTH=5000
MAX_CONCURRENT_EXPORTS=2
QUERY_TIMEOUT_MS=30000

# ── AI Cost Settlement (Optional) ───────────────────────
# OpenAI/Anthropic Admin API 키 — 빌링 페이지에서 사용량/비용 조회용
# OPENAI_ADMIN_API_KEY=sk-admin-xxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_ADMIN_API_KEY=sk-ant-admin-xxxxxxxxxxxxxxxxxxxx